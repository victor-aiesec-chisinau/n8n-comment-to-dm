    {
      "parameters": {
        "jsCode": "// Validate Meta webhook signature (X-Hub-Signature-256)\n// Set META_APP_SECRET env var to enable; omit to skip in dev/staging.\n// n8n parses the body before we can see it — re-serializing for HMAC\n// works for standard Meta payloads since V8 preserves key insertion order.\n\nconst { headers, body } = $input.first().json;\nconst appSecret = process.env.META_APP_SECRET || '';\n\nif (!appSecret) {\n  return [{ json: $input.first().json }];\n}\n\nconst sig = (headers && headers['x-hub-signature-256']) || '';\nif (!sig) {\n  return [];\n}\n\nconst crypto = require('crypto');\nconst expected = 'sha256=' + crypto.createHmac('sha256', appSecret)\n  .update(JSON.stringify(body))\n  .digest('hex');\n\nif (sig !== expected) {\n  return [];\n}\n\nreturn [{ json: $input.first().json }];"
      },
      "id": "a1b2c3d4-e5f6-7890-a1b2-c3d4e5f60001",
      "name": "Validate Signature",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [912, 400]
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body;\n\nif (!body || !body.entry || !Array.isArray(body.entry) || body.entry.length === 0) {\n  return [];\n}\n\nconst results = [];\n\nfor (const entry of body.entry) {\n  for (const change of (entry.changes || [])) {\n    const value = change.value;\n    if (!value) continue;\n\n    const commentText = value.text || value.message || '';\n    if (!commentText) continue;\n\n    const userId = value.from?.id || value.sender?.id || '';\n    if (!userId) continue;\n\n    // Skip edits and deletions — only process new comments\n    if (value.verb && value.verb !== 'add') continue;\n\n    // Skip replies-to-replies — only top-level comments trigger a DM\n    if (value.parent_id) continue;\n\n    results.push({\n      commentId: value.id,\n      commentText: commentText.toLowerCase().trim(),\n      userId,\n      username: value.from?.username || value.sender?.username || 'unknown',\n      mediaId: value.media?.id || value.post_id || '',\n      timestamp: new Date().toISOString(),\n      webhookType: change.field || 'unknown'\n    });\n  }\n}\n\nreturn results;"
      },
      "id": "d82f8a28-a21a-483b-9f01-d5c7f648f75a",
      "name": "Parse Instagram Comment",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1136, 400]
    },
    {
      "parameters": {
        "jsCode": "const commentText = $json.commentText;\n\nlet rules = [];\ntry {\n  rules = JSON.parse($env.KEYWORD_RULES);\n} catch (e) {\n  console.error('Failed to parse KEYWORD_RULES:', e.message);\n  return [];\n}\n\nconst activeRules = rules.filter(r =>\n  r.active === true && (!r.platform || r.platform === 'instagram')\n);\n\nfor (const rule of activeRules) {\n  if (!rule.keyword || typeof rule.keyword !== 'string') {\n    continue;\n  }\n  const keyword = rule.keyword.toLowerCase().trim();\n  const text = commentText.toLowerCase().trim();\n\n  let matched = false;\n  const matchType = rule.match_type || rule.matchType || 'contains';\n  if (matchType === 'exact') {\n    matched = text === keyword;\n  } else {\n    matched = text.includes(keyword);\n  }\n\n  if (matched) {\n    return [{\n      commentId: $json.commentId,\n      commentText: $json.commentText,\n      userId: $json.userId,\n      username: $json.username,\n      mediaId: $json.mediaId,\n      timestamp: $json.timestamp,\n      keyword: rule.keyword,\n      eventLink: rule.eventLink,\n      message: rule.message,\n      cooldownDays: rule.cooldownDays || 30\n    }];\n  }\n}\n\nreturn [];"
      },
